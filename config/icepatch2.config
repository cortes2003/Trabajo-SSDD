# IcePatch2 Server Configuration

# Nombre de la instancia
IcePatch2.InstanceName=SpotificeApp

# Directorio donde se almacenan los archivos a distribuir
IcePatch2.Directory=icepatch

# Endpoints del servidor IcePatch2
IcePatch2.Endpoints=tcp -p 10000

# Habilitar compresión para transferencias
Ice.Compression.Level=1

# Logs para debugging
# Ice.Trace.Network=1
