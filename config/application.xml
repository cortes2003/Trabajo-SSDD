<icegrid>
  <application name="SpotificeApp">
    
    <!-- ========================================= -->
    <!-- Servidor IcePatch2 para distribución     -->
    <!-- ========================================= -->
    <server-template id="IcePatch2Template">
      <parameter name="instance-name" default="${application}.IcePatch2"/>
      <server id="${instance-name}" exe="icepatch2server" activation="on-demand">
        <adapter name="IcePatch2" endpoints="tcp" register-process="true">
          <object identity="${instance-name}/server" type="::IcePatch2::FileServer"/>
        </adapter>
        <property name="IcePatch2.InstanceName" value="${instance-name}"/>
        <property name="IcePatch2.Directory" value="/home/alberto/Escritorio/Curso 2526/SSDD/Trabajo SSDD/Trabajo-SSDD/icepatch"/>
      </server>
    </server-template>

    <!-- ========================================= -->
    <!-- Template para MediaServer                 -->
    <!-- ========================================= -->
    <server-template id="MediaServerTemplate">
      <parameter name="index"/>
      <server id="MediaServer-${index}" exe="python3" activation="always" 
              pwd="/home/alberto/Escritorio/Curso 2526/SSDD/Trabajo SSDD/Trabajo-SSDD">
        <adapter name="MediaServerAdapter" endpoints="tcp" register-process="true">
          <object identity="mediaServer${index}" type="::Spotifice::MediaServer"/>
        </adapter>
        <option>media_server.py</option>
        <property name="Ice.StdErr" value="mediaserver${index}.log"/>
        <property name="Ice.StdOut" value="mediaserver${index}.log"/>
        <property name="MediaServer.Identity" value="mediaServer${index}"/>
        <property name="MediaServer.Content" value="/home/alberto/Escritorio/Curso 2526/SSDD/Trabajo SSDD/Trabajo-SSDD/media"/>
        <property name="MediaServer.Playlists" value="/home/alberto/Escritorio/Curso 2526/SSDD/Trabajo SSDD/Trabajo-SSDD/playlists"/>
      </server>
    </server-template>

    <!-- ========================================= -->
    <!-- Template para MediaRender                 -->
    <!-- ========================================= -->
    <server-template id="MediaRenderTemplate">
      <parameter name="index"/>
      <server id="MediaRender-${index}" exe="python3" activation="always"
              pwd="/home/alberto/Escritorio/Curso 2526/SSDD/Trabajo SSDD/Trabajo-SSDD">
        <adapter name="MediaRenderAdapter" endpoints="tcp" register-process="true">
          <object identity="mediaRender${index}" type="::Spotifice::MediaRender"/>
        </adapter>
        <option>media_render.py</option>
        <property name="Ice.StdErr" value="mediarender${index}.log"/>
        <property name="Ice.StdOut" value="mediarender${index}.log"/>
        <property name="MediaRender.Identity" value="mediaRender${index}"/>
      </server>
    </server-template>

    <!-- ========================================= -->
    <!-- NODO 1: IcePatch2 + 2 MediaServers        -->
    <!-- ========================================= -->
    <node name="node1">
      <!-- Servidor IcePatch2 -->
      <server-instance template="IcePatch2Template" instance-name="SpotificeApp.IcePatch2"/>
      
      <!-- MediaServer 1 -->
      <server-instance template="MediaServerTemplate" index="1"/>
      
      <!-- MediaServer 2 -->
      <server-instance template="MediaServerTemplate" index="2"/>
    </node>

    <!-- ========================================= -->
    <!-- NODO 2: 2 MediaRenders                    -->
    <!-- ========================================= -->
    <node name="node2">
      <!-- MediaRender 1 -->
      <server-instance template="MediaRenderTemplate" index="1"/>
      
      <!-- MediaRender 2 -->
      <server-instance template="MediaRenderTemplate" index="2"/>
    </node>

    <!-- ========================================= -->
    <!-- Configuración de distribución             -->
    <!-- ========================================= -->
    <distrib icepatch="SpotificeApp.IcePatch2/server"/>

  </application>
</icegrid>
